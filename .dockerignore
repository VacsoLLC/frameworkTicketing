# Anything not explicitly needed by docker/Dockerfile.ecs.
# Keeps local dev state out of the production image:
#  - node_modules can contain yarn-link symlinks that dangle in the container
#  - .env files contain real secrets generated by backend/generate_env.sh
#  - uploads grow unboundedly and are irrelevant to a fresh deploy

**/node_modules
**/.env
**/.env.*
!**/.env.example

.git
.gitignore
.github
.vscode
.devcontainer
.history

# Irrelevant top-level artifacts
docker/
frontend/
scripts/
terraform/
playwright-report/
test-results/
uploads/
TODO.md
LICENSE
README.md
*.code-workspace

# Test / coverage output anywhere
**/coverage
**/playwright-report
**/test-results
**/*.log

# Backend-specific ephemera
backend/uploads
backend/coverage
backend/test-results
backend/playwright-report
backend/.env
backend/tests
backend/TODO
